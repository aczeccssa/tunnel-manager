{
  "name": "tunnel-manager",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "check:versions": "node ./scripts/check-version-sync.mjs",
    "check:rust": "cargo check --manifest-path src-tauri/Cargo.toml",
    "check:rust:fmt": "cargo fmt --all --manifest-path src-tauri/Cargo.toml -- --check",
    "check:rust:clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets --all-features -- -D warnings",
    "verify": "npm run check:versions && npm run typecheck && npm run build && npm run check:rust && npm run check:rust:fmt && npm run check:rust:clippy",
    "ci:local": "npm run verify",
    "hooks:install": "node ./scripts/setup-githooks.mjs",
    "prepare": "npm run hooks:install",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/manrope": "^5.2.8",
    "@fontsource/material-symbols-outlined": "^5.2.38",
    "@hookform/resolvers": "^3.10.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-store": "^2.4.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.72.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
