{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "测试",
      "type": "shell",
      "command": "cargo",
      "args": [
        "test"
      ],
      "options": {
        "cwd": "${workspaceFolder}/src-tauri"
      },
      "group": "test",
      "problemMatcher": [
        "$rustc"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "编译",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "build"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": [
        "$tsc"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "开发运行",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "tauri",
        "--",
        "dev"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": [
        "$rustc"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Release 产出",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "tauri",
        "--",
        "build"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": [
        "$rustc"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "Debug 产出",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "tauri",
        "--",
        "build",
        "--debug"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": [
        "$rustc"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    }
  ]
}
